Select tootja, telephoneMODEL AS model FROM telephone;
--sorteerimine
--ASC kasvavas järjekorras
Select tootja, telephoneMODEL AS model, hind
FROM telephone
order by hind;
--DESC kahenavas jarjekorras
Select tootja, telephoneMODEL AS model, hind
FROM telephone
order by hind desc;

--VÕRDLEMINE >, <, =, >=, <=
Select telephoneMODEL, hind
FROM telephone
where hind >25 --leiab mudelid hinnaga suurem kui 25
ORDER by hind;
--leia mudelid vahemikus 10-20 euro
select telephoneMODEL, hind
from telephone
where hind between 10 and 20
order by hind;
--sama päring ilma between
select telephoneMODEL, hind
from telephone
where hind >=10  and hind<=20
order by hind;

--distinct ?! näitab ainult üks kordus
select distinct OS from telephone;

--võrdlemine tekstikga like 
select tootja, telephoneMODEL
from telephone
where tootja like 'Sony';
--IN kuvab vastuvus loetlus
select tootja, telephoneMODEL
from telephone
where tootja like 'Sony' or tootja like 'Samsung' or tootja like 'Honor'
--leia mudelid mis algavad S tähega
select tootja, telephoneMODEL
from telephone
where telephoneMODEL like 'S%';
--sisaldab s täht '%s%'

select AVG(v_aasta) as 'kesmineaasta'
from telephone;

select count(*) as 'üldkogus'
from telephone
group by tootja;
--top 6 
select top 6 tootja, hind
from telephone
order by tootja DESC

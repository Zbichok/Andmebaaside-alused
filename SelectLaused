create database timohamobile;
use timohamobile;

create table telephone (
	telephoneID INT primary key,
	tootja VARCHAR(50) not null,
	telephoneMODEL VARCHAR(50),
	hind money,
	v_aasta int,
	OS VARCHAR(10)
);

select * from telephone

alter table telephone alter column OS varchar(30);


create database Timohatriger
use Timohatriger

--tabel linnad
create table linnad(
linnId int primary key identity(1,1),
linnanimi varchar(50) unique,
rahvaarv int not null);
--tabel logi
CREATE TABLE logi(
Id int primary key identity(1,1),
kuupaev datetime,
andmed TEXT);

select * from linnad
select * from logi

--Insert Triger
Create TRIGGER linnaLisamine
on linnad
for insert
As
insert into logi(kuupaev, andmed)
Select
getdate(), inserted.linnanimi
from inserted;
